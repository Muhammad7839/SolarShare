# Backend runtime settings for local development and deployments.
ADMIN_PASSWORD=change_me_for_local_admin
SOLAR_SHARE_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
SOLAR_SHARE_CORS_ORIGIN_REGEX=^https?://192\\.168\\.\\d{1,3}\\.\\d{1,3}(:\\d+)?$
SOLAR_SHARE_HOST=127.0.0.1
SOLAR_SHARE_PORT=8000
SOLAR_SHARE_RELOAD=1
SOLAR_SHARE_IDEMPOTENCY_TTL_SECONDS=300
SOLAR_SHARE_CONTACT_DB_PATH=
SOLAR_SHARE_OPS_DB_PATH=
SOLAR_SHARE_REAL_DATA_DISABLE_NETWORK=0
SOLAR_SHARE_ASSISTANT_DISABLE_NETWORK=0
